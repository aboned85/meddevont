<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/meddevont#"
     xml:base="https://w3id.org/meddevont"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:meddevont="https://w3id.org/meddevont#">
    <owl:Ontology rdf:about="https://w3id.org/meddevont">
        <rdfs:comment>Ontology for the European catalogue of high risk medical devices under MDR and IVDR regulations</rdfs:comment>
        <rdfs:label>MedDevOnt: Medical Device Ontology</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->


    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <rdfs:comment>Relates a device to its manufacturer</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </rdf:Description>
    


    <!-- https://w3id.org/meddevont#addressesIncident -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#addressesIncident">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Relates a corrective action to the incident it addresses</rdfs:comment>
        <rdfs:label>addresses incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/meddevont#affectsDevice -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#affectsDevice">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:range rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment>Relates a corrective action to the device it affects</rdfs:comment>
        <rdfs:label>affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/meddevont#hasAssociatedRisk -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#hasAssociatedRisk">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Relates an incident to its identified risk</rdfs:comment>
        <rdfs:label>has associated risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/meddevont#hasManufacturer -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#hasManufacturer">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/meddevont#involvesDevice -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#involvesDevice">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Relates an incident to the device involved</rdfs:comment>
        <rdfs:label>involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/meddevont#reportedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/meddevont#reportedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:comment>Relates an incident to the reporting manufacturer</rdfs:comment>
        <rdfs:label>reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/meddevont#actionDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#actionDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Date the corrective action was initiated</rdfs:comment>
        <rdfs:label>action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#country -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#country">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country where the manufacturer is based</rdfs:comment>
        <rdfs:label>country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#deviceName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#deviceName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Commercial name of the medical device</rdfs:comment>
        <rdfs:label>device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#devicesAffected -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#devicesAffected">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Number or description of devices affected by the action</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#eudamedSRN">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Single Registration Number in EUDAMED</rdfs:comment>
        <rdfs:label>EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#imdrfCode -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#imdrfCode">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Risk code according to IMDRF nomenclature</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#isIVD -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#isIVD">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is an in vitro diagnostic</rdfs:comment>
        <rdfs:label>is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#isImplantable -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#isImplantable">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is implantable</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#manufacturerName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#manufacturerName">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Legal name of the manufacturer</rdfs:comment>
        <rdfs:label>manufacturer name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#outcome -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#outcome">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Clinical outcome of the incident</rdfs:comment>
        <rdfs:label>outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#probability -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#probability">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Probability level of the risk: Low, Medium or High</rdfs:comment>
        <rdfs:label>probability level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#reportDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#reportDate">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Date the incident was reported</rdfs:comment>
        <rdfs:label>report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#riskClass -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#riskClass">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Risk classification under MDR or IVDR</rdfs:comment>
        <rdfs:label>risk class</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#severity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#severity">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Severity level of the risk: Critical, Serious or Moderate</rdfs:comment>
        <rdfs:label>severity level</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#status -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#status">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current status of the corrective action: Open or Closed</rdfs:comment>
        <rdfs:label>action status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/meddevont#udiDI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/meddevont#udiDI">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique Device Identifier - Device Identifier</rdfs:comment>
        <rdfs:label>UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/meddevont#ActiveDevice -->


    <owl:Class rdf:about="https://w3id.org/meddevont#ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment xml:lang="en">A medical device that requires a source of electrical energy to function</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#ActiveImplant -->


    <owl:Class rdf:about="https://w3id.org/meddevont#ActiveImplant">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment>An implantable device with active electronic components</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#CybersecurityRisk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:comment>Risk of unauthorized access or cyberattack on a medical device</rdfs:comment>
        <rdfs:label>Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#Device -->


    <owl:Class rdf:about="https://w3id.org/meddevont#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/meddevont#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/meddevont#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A medical device registered under EU MDR or IVDR regulations</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Medical_device"/>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#DiagnosticRisk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:comment>Risk of incorrect diagnostic results from an IVD device</rdfs:comment>
        <rdfs:label>Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#FSCA -->


    <owl:Class rdf:about="https://w3id.org/meddevont#FSCA">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/meddevont#addressesIncident"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/meddevont#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A corrective action taken by a manufacturer to address a safety issue</rdfs:comment>
        <rdfs:label>Field Safety Corrective Action</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Corrective_and_preventive_action"/>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#IVDR -->


    <owl:Class rdf:about="https://w3id.org/meddevont#IVDR">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#RegulatoryFramework"/>
        <rdfs:comment>EU Regulation 2017/746 on in vitro diagnostic medical devices</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Regulation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#ImplantableActiveDevice -->


    <owl:Class rdf:about="https://w3id.org/meddevont#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment>An active device intended to be implanted in the human body</rdfs:comment>
        <rdfs:label>Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#ImplantableDevice -->


    <owl:Class rdf:about="https://w3id.org/meddevont#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment>A device intended to be implanted in the human body</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#InSituCorrection -->


    <owl:Class rdf:about="https://w3id.org/meddevont#InSituCorrection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:comment>On site modification or update of a device to address a safety issue</rdfs:comment>
        <rdfs:label>In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="https://w3id.org/meddevont#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Device"/>
        <rdfs:comment>A device used for in vitro examination of specimens from the human body</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#Incident -->


    <owl:Class rdf:about="https://w3id.org/meddevont#Incident">
        <rdfs:comment>A safety incident reported in relation to a medical device</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#InfectionRisk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#InfectionRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:comment>Risk of device-related infection</rdfs:comment>
        <rdfs:label>Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#InjuryRisk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#InjuryRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:comment>Risk of physical injury to the patient</rdfs:comment>
        <rdfs:label>Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#MDR -->


    <owl:Class rdf:about="https://w3id.org/meddevont#MDR">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#RegulatoryFramework"/>
        <rdfs:comment>EU Regulation 2017/745 on medical devices</rdfs:comment>
        <rdfs:label>Medical Device Regulation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#MalfunctionRisk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Risk"/>
        <rdfs:comment>Risk related to device malfunction or failure</rdfs:comment>
        <rdfs:label>Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#Manufacturer -->


    <owl:Class rdf:about="https://w3id.org/meddevont#Manufacturer">
        <rdfs:comment>Organization responsible for the design and production of a medical device</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#NearMissIncident -->


    <owl:Class rdf:about="https://w3id.org/meddevont#NearMissIncident">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#Incident"/>
        <rdfs:comment>An incident that could have led to harm but was detected before affecting the patient</rdfs:comment>
        <rdfs:label>Near Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#Recall -->


    <owl:Class rdf:about="https://w3id.org/meddevont#Recall">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:comment>Removal of a medical device from the market or from use</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#RegulatoryFramework -->


    <owl:Class rdf:about="https://w3id.org/meddevont#RegulatoryFramework">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/meddevont#involvesDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/meddevont#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>European regulatory framework governing medical devices</rdfs:comment>
        <rdfs:label>Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#Risk -->


    <owl:Class rdf:about="https://w3id.org/meddevont#Risk">
        <rdfs:comment>An identified risk associated with a medical device according to IMDRF nomenclature</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/meddevont#SafetyAlert -->


    <owl:Class rdf:about="https://w3id.org/meddevont#SafetyAlert">
        <rdfs:subClassOf rdf:resource="https://w3id.org/meddevont#FSCA"/>
        <rdfs:comment>Communication to users about a safety issue with a device</rdfs:comment>
        <rdfs:label>Safety Alert</rdfs:label>
    </owl:Class>
    


